{
    "name": "marvinpay/laravel",
    "description": "Laravel integration for the Marvin Pay mobile-money payment gateway: MarvinPay service + facade, config, webhook middleware and example controller/route.",
    "type": "library",
    "keywords": ["marvinpay", "laravel", "payment", "mobile-money", "xaf", "xof"],
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/http": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "MarvinPay\\Laravel\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MarvinPay\\Laravel\\MarvinPayServiceProvider"
            ],
            "aliases": {
                "MarvinPay": "MarvinPay\\Laravel\\Facades\\MarvinPay"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
