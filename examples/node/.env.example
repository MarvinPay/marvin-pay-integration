# Copy to `.env` and fill in. These examples read config from the environment.
#
# Your Marvin Pay merchant API key (sent as the X-API-KEY header).
MARVIN_API_KEY=your-api-key-here

# Base URL. Optional — defaults to production if unset.
#   Production : https://api.marvincorporate.co/api
#   Local/dev  : http://localhost:9090/api
# Note: the base URL MUST include the /api context path.
MARVIN_BASE_URL=https://api.marvincorporate.co/api

# Optional — used by the webhook example to verify the X-Webhook-Signature header.
# Set it to your account's webhook secret once configured; always confirm via
# getStatus regardless.
MARVIN_WEBHOOK_SECRET=

# Optional — port for the webhook example server.
PORT=3000
