# Marvin Pay — example configuration.
# Copy to `.env` and fill in, then export these into your shell before running
# the examples (the examples read them via os.environ; they do not auto-load .env).
#
#   set -a; . ./.env; set +a        # bash/zsh
#
# ---------------------------------------------------------------------------

# Your merchant API key (sent as X-API-KEY). Required for collect/payout/status.
# Optional for the public pay_invoice flow.
MARVIN_API_KEY=your_api_key_here

# API base URL, including the /api context path.
#   Production : https://api.marvincorporate.co/api   (default)
#   Local/dev  : http://localhost:9090/api
MARVIN_BASE_URL=https://api.marvincorporate.co/api

# Your webhookSecret (for webhook_flask.py). Webhooks are UNSIGNED today, so this
# is currently unused by the server — keep confirming via get_status regardless.
MARVIN_WEBHOOK_SECRET=

# --- Optional overrides for the collect/payout/pay_invoice examples ---
# Currency and country ALWAYS travel together.
MARVIN_COUNTRY=CM
MARVIN_CURRENCY=XAF
MARVIN_PAYMENT_METHOD=mtn_cm
MARVIN_MOBILE_NUMBER=237670000001
MARVIN_AMOUNT=5000
MARVIN_BENEFICIARY=Jane Doe

# For pay_invoice.py (or pass the reference as the first CLI argument).
MARVIN_INVOICE_REFERENCE=
